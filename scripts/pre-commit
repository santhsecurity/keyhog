#!/bin/bash
#
# KeyHog Secret Scanner - Production Pre-commit Hook
#
# This script scans staged files for secrets before allowing a commit.
# It blocks commits if any findings with confidence >= MIN_CONFIDENCE are found.
#
# Features:
#   - Scans only staged files (git diff --cached --name-only --diff-filter=ACM)
#   - Creates isolated temp directory with staged content
#   - Runs under 2 seconds for typical commits (<50 files)
#   - Prints findings with file:line format
#   - Exit code 1 if secrets found, 0 otherwise
#
# Installation:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Or use with pre-commit framework (see .pre-commit-config.yaml)
#

set -euo pipefail

# Configuration
MIN_CONFIDENCE="0.5"
DETECTORS_DIR="${KEYHOG_DETECTORS:-detectors}"
KEYHOG_BIN="${KEYHOG_BIN:-target/release/keyhog}"
MAX_FILES="${KEYHOG_MAX_FILES:-100}"
MAX_FILE_SIZE="${KEYHOG_MAX_FILE_SIZE:-1048576}"  # 1MB

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Function to print colored output
print_error() { echo -e "${RED}✗ $1${NC}" >&2; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}" >&2; }
print_success() { echo -e "${GREEN}✓ $1${NC}" >&2; }
print_info() { echo -e "${BLUE}ℹ $1${NC}" >&2; }
print_bold() { echo -e "${BOLD}$1${NC}"; }

# Check if keyhog binary exists
if [[ ! -x "$KEYHOG_BIN" ]]; then
    # Try to find it in PATH
    if command -v keyhog &> /dev/null; then
        KEYHOG_BIN=$(command -v keyhog)
    else
        print_error "KeyHog scanner not found at $KEYHOG_BIN"
        echo ""
        echo "To fix:"
        echo "  1. Build the scanner: cargo build --release -p keyhog"
        echo "  2. Or set KEYHOG_BIN to the binary path"
        exit 1
    fi
fi

# Get the list of staged files (Added, Copied, Modified - NOT Deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

# Count staged files for reporting
FILE_COUNT=$(echo "$STAGED_FILES" | wc -l)

if [[ "$FILE_COUNT" -gt "$MAX_FILES" ]]; then
    print_warning "Too many staged files ($FILE_COUNT > $MAX_FILES), scanning first $MAX_FILES files"
    STAGED_FILES=$(echo "$STAGED_FILES" | head -n "$MAX_FILES")
    FILE_COUNT=$MAX_FILES
fi

echo "🔒 KeyHog: Scanning $FILE_COUNT staged file(s) for secrets..."

# Create temporary directory for staged content
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

# Export staged files to temp directory
VALID_FILES=()
FILE_COUNT=0

while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    
    # Get file size from staged content
    local_size=$(git cat-file -s ":$file" 2>/dev/null || echo "0")
    
    # Skip files larger than MAX_FILE_SIZE
    if [[ "$local_size" -gt "$MAX_FILE_SIZE" ]]; then
        continue
    fi
    
    # Create directory structure in temp dir
    mkdir -p "$TEMP_DIR/$(dirname "$file")"
    
    # Export staged content to temp file
    if git show ":$file" > "$TEMP_DIR/$file" 2>/dev/null; then
        VALID_FILES+=("$file")
        FILE_COUNT=$((FILE_COUNT + 1))
    fi
done <<< "$STAGED_FILES"

if [[ ${#VALID_FILES[@]} -eq 0 ]]; then
    print_success "No text files to scan (skipped binary/large files)"
    exit 0
fi

# Build detectors path - handle both absolute and relative paths
if [[ ! -d "$DETECTORS_DIR" ]]; then
    # Try relative to git root
    GIT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    if [[ -d "$GIT_ROOT/$DETECTORS_DIR" ]]; then
        DETECTORS_DIR="$GIT_ROOT/$DETECTORS_DIR"
    else
        print_error "Detectors directory not found: $DETECTORS_DIR"
        exit 1
    fi
fi

# Run KeyHog scan
SCAN_START=$(date +%s%3N)

# Use JSONL format for structured output parsing
OUTPUT_FILE=$(mktemp)
trap "rm -rf $TEMP_DIR $OUTPUT_FILE" EXIT

set +e
"$KEYHOG_BIN" scan \
    --path "$TEMP_DIR" \
    --detectors "$DETECTORS_DIR" \
    --min-confidence "$MIN_CONFIDENCE" \
    --format jsonl \
    2>/dev/null \
    > "$OUTPUT_FILE"
SCAN_EXIT_CODE=$?
set -e

SCAN_END=$(date +%s%3N)
SCAN_MS=$((SCAN_END - SCAN_START))

# Count findings (grep -c outputs 0 and exits 1 when no matches)
FINDING_COUNT=$(grep -c '^{' "$OUTPUT_FILE" 2>/dev/null || true)
# Ensure it's a number
if [[ -z "$FINDING_COUNT" ]] || ! [[ "$FINDING_COUNT" =~ ^[0-9]+$ ]]; then
    FINDING_COUNT=0
fi

if [[ "$FINDING_COUNT" -gt 0 ]]; then
    echo ""
    print_error "COMMIT BLOCKED: $FINDING_COUNT secret(s) detected!"
    echo ""
    print_bold "Findings:"
    echo ""
    
    # Parse JSONL and print in file:line format
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        
        # Extract fields using basic parsing (no jq dependency)
        file=$(echo "$line" | grep -o '"path":"[^"]*"' | cut -d'"' -f4 | sed "s|$TEMP_DIR/||")
        line_num=$(echo "$line" | grep -o '"line":[0-9]*' | cut -d':' -f2)
        detector=$(echo "$line" | grep -o '"detector_name":"[^"]*"' | cut -d'"' -f4)
        service=$(echo "$line" | grep -o '"service":"[^"]*"' | cut -d'"' -f4)
        severity=$(echo "$line" | grep -o '"severity":"[^"]*"' | cut -d'"' -f4)
        
        # Print in file:line format
        echo -e "  ${RED}$file:$line_num${NC} - $detector ($service, $severity severity)"
    done < "$OUTPUT_FILE"
    
    echo ""
    print_bold "To fix:"
    echo "  1. Remove the secrets from your files"
    echo "  2. Use environment variables or a secrets manager"
    echo "  3. Add false positives to .keyhogignore"
    echo ""
    print_bold "To bypass (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

print_success "No secrets detected (${SCAN_MS}ms) - commit allowed"
exit 0
