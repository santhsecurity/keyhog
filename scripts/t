#!/usr/bin/env bash
# t — single-run test harness with cached output views.
# Run once, query many times. Prevents agents from re-running cargo test N times.
#
# Usage:
#   t              — run tests (or show cached if source unchanged), print summary
#   t full         — show full cached output
#   t failures     — show only failures
#   t summary      — show only result lines
#   t warnings     — show only compiler warnings
#   t check        — cargo check only (cached)
#   t clippy       — cargo clippy (cached)
#   t invalidate   — force re-run next time
#   t status       — show cache age and whether it's stale
#
# Cache is invalidated automatically when any .rs file is newer than the cache.

set -euo pipefail

CACHE_DIR="/tmp/keyhog-test-cache"
mkdir -p "$CACHE_DIR"

TEST_OUTPUT="$CACHE_DIR/test.out"
CHECK_OUTPUT="$CACHE_DIR/check.out"
CLIPPY_OUTPUT="$CACHE_DIR/clippy.out"
HASH_FILE="$CACHE_DIR/source.hash"
PROJECT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

compute_hash() {
    find "$PROJECT_ROOT" -name '*.rs' -o -name 'Cargo.toml' -o -name 'Cargo.lock' \
        | sort | xargs stat --format='%n %Y' 2>/dev/null \
        | sha256sum | cut -d' ' -f1
}

is_stale() {
    local cache_file="$1"
    [ ! -f "$cache_file" ] && return 0
    [ ! -f "$HASH_FILE" ] && return 0
    local current
    current="$(compute_hash)"
    local stored
    stored="$(cat "$HASH_FILE")"
    [ "$current" != "$stored" ]
}

save_hash() {
    compute_hash > "$HASH_FILE"
}

run_tests() {
    if is_stale "$TEST_OUTPUT"; then
        printf "\033[1;34m▸ Running cargo test --workspace...\033[0m\n"
        cd "$PROJECT_ROOT"
        cargo test --workspace 2>&1 | tee "$TEST_OUTPUT"
        save_hash
        printf "\n\033[1;32m▸ Cached at %s\033[0m\n" "$TEST_OUTPUT"
    else
        local age
        age=$(( ($(date +%s) - $(stat --format='%Y' "$TEST_OUTPUT")) ))
        printf "\033[1;33m▸ Using cached results (%ds old). Run 't invalidate' to force re-run.\033[0m\n\n"  "$age"
        cat "$TEST_OUTPUT"
    fi
}

run_check() {
    if is_stale "$CHECK_OUTPUT"; then
        printf "\033[1;34m▸ Running cargo check --workspace...\033[0m\n"
        cd "$PROJECT_ROOT"
        cargo check --workspace 2>&1 | tee "$CHECK_OUTPUT"
        save_hash
    else
        printf "\033[1;33m▸ Using cached check results.\033[0m\n\n"
        cat "$CHECK_OUTPUT"
    fi
}

run_clippy() {
    if is_stale "$CLIPPY_OUTPUT"; then
        printf "\033[1;34m▸ Running cargo clippy --workspace...\033[0m\n"
        cd "$PROJECT_ROOT"
        cargo clippy --workspace -- -D warnings 2>&1 | tee "$CLIPPY_OUTPUT"
        save_hash
    else
        printf "\033[1;33m▸ Using cached clippy results.\033[0m\n\n"
        cat "$CLIPPY_OUTPUT"
    fi
}

show_summary() {
    [ ! -f "$TEST_OUTPUT" ] && { echo "No cached test output. Run 't' first."; exit 1; }
    echo "=== Test Summary ==="
    grep -E '^(running |test result:|test .* \.\.\. (FAILED|ok))' "$TEST_OUTPUT" || true
    echo ""
    echo "=== Warnings ==="
    grep -c '^warning' "$TEST_OUTPUT" 2>/dev/null | xargs printf "%s warnings\n" || echo "0 warnings"
    echo ""
    echo "=== Failures ==="
    grep -c 'FAILED' "$TEST_OUTPUT" 2>/dev/null | xargs printf "%s failures\n" || echo "0 failures"
}

show_failures() {
    [ ! -f "$TEST_OUTPUT" ] && { echo "No cached test output. Run 't' first."; exit 1; }
    grep -A5 'FAILED\|panicked\|^error' "$TEST_OUTPUT" || echo "No failures found."
}

show_warnings() {
    [ ! -f "$TEST_OUTPUT" ] && { echo "No cached test output. Run 't' first."; exit 1; }
    grep '^warning' "$TEST_OUTPUT" || echo "No warnings."
}

show_status() {
    for f in "$TEST_OUTPUT" "$CHECK_OUTPUT" "$CLIPPY_OUTPUT"; do
        local name
        name="$(basename "$f" .out)"
        if [ -f "$f" ]; then
            local age
            age=$(( ($(date +%s) - $(stat --format='%Y' "$f")) ))
            local stale_marker=""
            is_stale "$f" && stale_marker=" (STALE)"
            printf "%-10s %ds old%s\n" "$name" "$age" "$stale_marker"
        else
            printf "%-10s not cached\n" "$name"
        fi
    done
}

case "${1:-run}" in
    run|test)    run_tests ;;
    full)        [ -f "$TEST_OUTPUT" ] && cat "$TEST_OUTPUT" || echo "No cache. Run 't' first." ;;
    failures)    show_failures ;;
    summary)     show_summary ;;
    warnings)    show_warnings ;;
    check)       run_check ;;
    clippy)      run_clippy ;;
    invalidate)  rm -f "$HASH_FILE"; echo "Cache invalidated." ;;
    status)      show_status ;;
    *)           echo "Usage: t [run|full|failures|summary|warnings|check|clippy|invalidate|status]" ;;
esac
